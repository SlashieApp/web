    "@hookform/resolvers": "^5.2.2",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "graphql": "^16.12.0",
    "mapbox-gl": "^3.17.0",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "posthog-js": "^1.360.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@chromatic-com/storybook": "^5.0.0",
